{
  "cleanUrls": true,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "api/vuelos/index.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "rewrites": [
    {
      "source": "/api/vuelos/",
      "destination": "/api/vuelos/index.php"
    },
    {
      "source": "/(.*\\.php)$",
      "destination": "/api/index.php"
    }
  ]
}
