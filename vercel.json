{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "*.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "dinadatos/**/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/api/vuelos/",
      "dest": "/api/vuelos/index.php"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
