{
  "cleanUrls": true,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "api/vuelos/index.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/api/vuelos/",
      "dest": "/api/vuelos/index.php"
    },
    {
      "src": "/php_sources/(.*)",
      "status": 403,
      "dest": "/"
    },
    {
      "src": "/(.*\\.php)$",
      "dest": "/api/index.php"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
